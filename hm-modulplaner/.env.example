# ── HM Modulplaner – Umgebungsvariablen ──────────────────────────────────────
# Kopiere diese Datei als .env.local und trage deine Werte ein.
# WICHTIG: .env.local NIEMALS ins Repository committen!
# Keine echten Zugangsdaten in diese Datei schreiben!

# Basis-URL der NINE-API
VITE_NINE_API_BASE_URL=https://nine.hm.edu

# API-Modus: "live" = echte API-Aufrufe, "mock" = nur lokale Fallback-Daten
VITE_NINE_API_MODE=live

# Studiengang (für /api/v2/modules/{curriculum}/{stage}/{semester})
VITE_NINE_CURRICULUM=WI

# Semester-ID (exakte Schreibweise aus GET /api/v2/semester)
VITE_NINE_TERM=SoSe 2026

# HM-Zugangsdaten für POST /api/v2/account/login
# NIEMALS echte Werte in diese Datei schreiben!
VITE_NINE_USERNAME=
VITE_NINE_PASSWORD=

# Bearer Token (nach Login erhalten, oder manuell aus HM-Portal kopiert)
# NIEMALS ins Repository committen!
VITE_NINE_TOKEN=

# Organiser-ID (WI = "FK 09", aus GET /api/v2/organisers)
VITE_NINE_API_ORGANISER=FK 09

# Institution-ID (für /courses, /curricula)
VITE_NINE_API_INSTITUTION=FK 09

# ── Agent-Server (agent-server/server.ts) ────────────────────────────────────
# Port des lokalen Agent-Servers (Standard: 3001, nicht nach außen exponieren)
AGENT_PORT=3001

# Moodle – NIEMALS echte Werte in diese Datei schreiben!
# Persönlicher Moodle Web Services Token (Profil → Sicherheitsschlüssel)
MOODLE_BASE_URL=https://moodle.hm.edu
MOODLE_TOKEN=
